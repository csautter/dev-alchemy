{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "enabledManagers": [
    "custom.regex"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update PowerShell devcontainer tarball version and SHA256 pins",
      "managerFilePatterns": [
        "/(^|/)\\.devcontainer/Dockerfile$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)\\s+versioning=(?<versioning>\\S+)\\s+ENV\\s+POWERSHELL_VERSION=\"(?<currentValue>[^\"]+)\"\\s+ENV\\s+POWERSHELL_SHA256_X64=\"(?<currentDigest>[a-f0-9]{64})\"",
        "# renovate: datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)\\s+version=(?<currentValue>\\S+)\\s+versioning=(?<versioning>\\S+)\\s+ENV\\s+POWERSHELL_SHA256_ARM64=\"(?<currentDigest>[a-f0-9]{64})\""
      ]
    },
    {
      "customType": "regex",
      "description": "Update annotated custom dependency pins in Go and shell scripts",
      "managerFilePatterns": [
        "/(^|/)\\.github/runners/prepare-tart-base\\.sh$/",
        "/(^|/)scripts/macos/dev-alchemy-install-dependencies\\.sh$/",
        "/(^|/)pkg/build/dependencies\\.go$/",
        "/(^|/)build/packer/linux/ubuntu/linux-ubuntu-(on-macos|qemu)\\.sh$/",
        "/(^|/)scripts/macos/download-virtio-win-iso\\.sh$/",
        "/(^|/)scripts/windows/dev-alchemy-self-setup\\.ps1$/"
      ],
      "matchStrings": [
        "(?:#|//)\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)(?:\\s+packageName=(?<packageName>\\S+))?\\s+versioning=(?<versioning>\\S+)(?:\\s+registryUrl=(?<registryUrl>\\S+))?\\s+\\$?[A-Za-z0-9_]+\\s*=\\s*\"(?<currentValue>[^\"]+)\"(?:\\s+\\$?[A-Za-z0-9_]+\\s*=\\s*\"(?<currentDigest>[a-f0-9]+)\")?"
      ]
    },
    {
      "customType": "regex",
      "description": "Update HashiCorp Packer plugin version constraints in .pkr.hcl files",
      "managerFilePatterns": [
        "/(^|/)build/.+\\.pkr\\.hcl$/"
      ],
      "matchStrings": [
        "(?<plugin>[a-z0-9-]+)\\s*=\\s*\\{\\s*source\\s*=\\s*\"github.com/hashicorp/[^\"]+\"\\s*\\n\\s*version\\s*=\\s*\"[~><= ]*(?<currentValue>[0-9][^\"]*)\"\\s*\\}",
        "(?<plugin>[a-z0-9-]+)\\s*=\\s*\\{\\s*version\\s*=\\s*\"[~><= ]*(?<currentValue>[0-9][^\"]*)\"\\s*\\n\\s*source\\s*=\\s*\"github.com/hashicorp/[^\"]+\"\\s*\\}"
      ],
      "depNameTemplate": "hashicorp/packer-plugin-{{{plugin}}}",
      "datasourceTemplate": "github-tags",
      "extractVersionTemplate": "^v(?<version>.*)$"
    },
    {
      "customType": "regex",
      "description": "Update Ubuntu live-server amd64 version defaults in Packer templates",
      "managerFilePatterns": [
        "/(^|/)build/packer/linux/ubuntu/linux-ubuntu-hyperv\\.pkr\\.hcl$/"
      ],
      "matchStrings": [
        "variable\\s+\"ubuntu_version\"\\s+\\{[\\s\\S]*?default\\s*=\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "ubuntu-live-server-amd64",
      "datasourceTemplate": "custom.ubuntu-live-server-amd64",
      "versioningTemplate": "loose"
    },
    {
      "customType": "regex",
      "description": "Update Ubuntu live-server amd64 ISO filename references",
      "managerFilePatterns": [
        "/(^|/)\\.github/workflows/test-build-(linux|macos)\\.yml$/",
        "/(^|/)build/packer/linux/ubuntu/README\\.md$/"
      ],
      "matchStrings": [
        "ubuntu-(?<currentValue>[0-9]{2}\\.[0-9]{2}(?:\\.[0-9]+)?)-live-server-amd64\\.iso"
      ],
      "depNameTemplate": "ubuntu-live-server-amd64",
      "datasourceTemplate": "custom.ubuntu-live-server-amd64",
      "versioningTemplate": "loose"
    },
    {
      "customType": "regex",
      "description": "Update Ubuntu live-server arm64 ISO filename references",
      "managerFilePatterns": [
        "/(^|/)\\.github/workflows/test-build-(linux|macos)\\.yml$/"
      ],
      "matchStrings": [
        "ubuntu-(?<currentValue>[0-9]{2}\\.[0-9]{2}(?:\\.[0-9]+)?)-live-server-arm64\\.iso"
      ],
      "depNameTemplate": "ubuntu-live-server-arm64",
      "datasourceTemplate": "custom.ubuntu-live-server-arm64",
      "versioningTemplate": "loose"
    },
    {
      "customType": "regex",
      "description": "Update k9s role version pin",
      "managerFilePatterns": [
        "/(^|/)roles/k9s/defaults/main\\.yml$/"
      ],
      "matchStrings": [
        "k9s_version:\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "derailed/k9s",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "description": "Update kind role version pin",
      "managerFilePatterns": [
        "/(^|/)roles/kind/defaults/main\\.yml$/"
      ],
      "matchStrings": [
        "kind_version:\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "kubernetes-sigs/kind",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "description": "Update kubectl role version pin",
      "managerFilePatterns": [
        "/(^|/)roles/kubectl/defaults/main\\.yml$/"
      ],
      "matchStrings": [
        "kubectl_version:\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "kubernetes/kubernetes",
      "datasourceTemplate": "github-tags",
      "extractVersionTemplate": "^v(?<version>.*)$"
    },
    {
      "customType": "regex",
      "description": "Update gosec install references",
      "managerFilePatterns": [
        "/(^|/)\\.devcontainer/Dockerfile$/",
        "/(^|/)Makefile$/"
      ],
      "matchStrings": [
        "github\\.com/securego/gosec/v2/cmd/gosec@v(?<currentValue>[0-9.]+)"
      ],
      "depNameTemplate": "securego/gosec",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "description": "Update GitHub Actions runner version in the Azure runner image",
      "managerFilePatterns": [
        "/(^|/)build/gh_actions/windows-azure-gh-runner\\.pkr\\.hcl$/"
      ],
      "matchStrings": [
        "variable\\s+\"github_actions_version\"\\s+\\{[\\s\\S]*?default\\s*=\\s*\"(?<currentValue>[0-9.]+)\""
      ],
      "depNameTemplate": "actions/runner",
      "datasourceTemplate": "github-releases"
    }
  ],
  "customDatasources": {
    "homebrew-formula": {
      "defaultRegistryUrlTemplate": "https://formulae.brew.sh/api/formula/{{packageName}}.json",
      "format": "json",
      "transformTemplates": [
        "{ \"releases\": [{ \"version\": versions.stable }] }"
      ]
    },
    "homebrew-cask": {
      "defaultRegistryUrlTemplate": "https://formulae.brew.sh/api/cask/{{packageName}}.json",
      "format": "json",
      "transformTemplates": [
        "{ \"releases\": [{ \"version\": version }] }"
      ]
    },
    "hashicorp": {
      "defaultRegistryUrlTemplate": "https://api.releases.hashicorp.com/v1/releases/{{packageName}}?license_class=oss",
      "format": "json",
      "transformTemplates": [
        "{ \"releases\": $map($, function($v) { { \"version\": $v.version, \"releaseTimestamp\": $v.timestamp_created, \"changelogUrl\": $v.url_changelog, \"sourceUrl\": $v.url_source_repository } }), \"homepage\": $[0].url_project_website, \"sourceUrl\": $[0].url_source_repository }"
      ]
    },
    "powershell-linux-x64": {
      "defaultRegistryUrlTemplate": "https://api.github.com/repos/PowerShell/PowerShell/releases?per_page=100",
      "format": "json",
      "transformTemplates": [
        "{ \"releases\": ( $githubReleases := $type($) = \"array\" ? $ : []; $append([], $filter($map($githubReleases, function($release) { $exists($release.tag_name) and $exists($release.assets) ? ( $version := $replace($release.tag_name, /^v/, \"\"); $asset := $release.assets[name = \"powershell-\" & $version & \"-linux-x64.tar.gz\"][0]; $type($asset.digest) = \"string\" ? { \"version\": $version, \"releaseTimestamp\": $release.published_at, \"sourceUrl\": $release.html_url, \"digest\": $replace($asset.digest, /^sha256:/, \"\"), \"isStable\": $not($release.prerelease) } : undefined ) : undefined }), function($item) { $exists($item) })) ) }"
      ]
    },
    "powershell-linux-arm64": {
      "defaultRegistryUrlTemplate": "https://api.github.com/repos/PowerShell/PowerShell/releases?per_page=100",
      "format": "json",
      "transformTemplates": [
        "{ \"releases\": ( $githubReleases := $type($) = \"array\" ? $ : []; $append([], $filter($map($githubReleases, function($release) { $exists($release.tag_name) and $exists($release.assets) ? ( $version := $replace($release.tag_name, /^v/, \"\"); $asset := $release.assets[name = \"powershell-\" & $version & \"-linux-arm64.tar.gz\"][0]; $type($asset.digest) = \"string\" ? { \"version\": $version, \"releaseTimestamp\": $release.published_at, \"sourceUrl\": $release.html_url, \"digest\": $replace($asset.digest, /^sha256:/, \"\"), \"isStable\": $not($release.prerelease) } : undefined ) : undefined }), function($item) { $exists($item) })) ) }"
      ]
    },
    "ubuntu-live-server-amd64": {
      "defaultRegistryUrlTemplate": "https://releases.ubuntu.com/24.04/SHA256SUMS",
      "format": "plain",
      "transformTemplates": [
        "{ \"releases\": $map(releases[$match(version, /^[a-f0-9]{64} \\*ubuntu-[0-9]{2}\\.[0-9]{2}(\\.[0-9]+)?-live-server-amd64\\.iso$/)], function($v) { { \"version\": $replace($split($v.version, \" *ubuntu-\")[1], /-live-server-amd64\\.iso$/, \"\"), \"digest\": $split($v.version, \" *ubuntu-\")[0] } }) }"
      ]
    },
    "ubuntu-live-server-arm64": {
      "defaultRegistryUrlTemplate": "https://cdimage.ubuntu.com/releases/24.04/release/SHA256SUMS",
      "format": "plain",
      "transformTemplates": [
        "{ \"releases\": $map(releases[$match(version, /^[a-f0-9]{64} \\*ubuntu-[0-9]{2}\\.[0-9]{2}(\\.[0-9]+)?-live-server-arm64\\.iso$/)], function($v) { { \"version\": $replace($split($v.version, \" *ubuntu-\")[1], /-live-server-arm64\\.iso$/, \"\"), \"digest\": $split($v.version, \" *ubuntu-\")[0] } }) }"
      ]
    },
    "virtio-win": {
      "defaultRegistryUrlTemplate": "https://fedorapeople.org/groups/virt/virtio-win/direct-downloads/archive-virtio/",
      "format": "html"
    }
  },
  "packageRules": [
    {
      "matchDatasources": [
        "custom.virtio-win"
      ],
      "extractVersion": "^virtio-win-(?<version>0\\.1\\.\\d+-\\d+)/$"
    },
    {
      "matchPackageNames": [
        "ubuntu-live-server-amd64",
        "ubuntu-live-server-arm64"
      ],
      "groupName": "Ubuntu live server artifacts"
    },
    {
      "matchDatasources": [
        "custom.powershell-linux-x64",
        "custom.powershell-linux-arm64"
      ],
      "matchPackageNames": [
        "PowerShell/PowerShell"
      ],
      "groupName": "PowerShell devcontainer artifacts"
    }
  ]
}
