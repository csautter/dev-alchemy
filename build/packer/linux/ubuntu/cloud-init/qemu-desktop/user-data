#cloud-config

autoinstall:
  version: 1
  early-commands:
    - |
      if [ -x /usr/bin/busctl ] && [ ! -x /usr/bin/busctl.dev-alchemy-original ]; then
        mv /usr/bin/busctl /usr/bin/busctl.dev-alchemy-original
        cat >/usr/bin/busctl <<'EOF'
      #!/bin/sh
      exec /usr/bin/busctl.dev-alchemy-original --timeout=120 "$@"
      EOF
        chmod 0755 /usr/bin/busctl
      fi
  identity:
    hostname: ubuntu-desktop
    username: packer
    password: "$6$K0/99yci1FVwggFy$/v7bEfr0MBcNq6teIkKkTjHMzJo9UE8q0IdrIORqycbldC.WgYtDhVdlEfqNgM7kN/zEuJX1KAr4kRAgHKn/.." # mkpasswd --method=SHA-512
  ssh:
    install-server: true
  storage:
    layout:
      name: direct
  network:
    version: 2
    ethernets:
      default:
        dhcp4: true
        dhcp6: true
        match:
          name: e*
  language: de
  locale: de_DE.UTF-8
  keyboard:
    layout: de
  apt:
    fallback: offline-install
    geoip: false
